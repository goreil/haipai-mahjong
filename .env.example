# Required — Flask session signing key. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional — set to "development" for debug mode and non-secure cookies
# FLASK_ENV=development

# Optional — path to mahjong-cpp shared library (default: searches next to mahjong_cpp.py, then mahjong-cpp/build/)
# MAHJONG_CPP_LIB=/opt/mahjong-cpp/libmahjongcpp.so

# Optional — path to SQLite database (default: games.db in project root)
# DB_PATH=/app/data/games.db

# Optional — GitHub personal access token for creating issues from feedback
# GITHUB_TOKEN=ghp_...

# Optional — GitHub repo for issue creation (default: goreil/haipai-mahjong)
# GITHUB_REPO=goreil/haipai-mahjong

# Optional — Discord webhook URL for new feedback notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
